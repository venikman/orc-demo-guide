{
  "name": "orc-demo-guide",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"bun run dev:server\" \"bun run dev:client\"",
    "dev:client": "vite",
    "dev:server": "bun --watch src/server/index.ts",
    "dev:gemini": "bun run dev",
    "import:public-fhir": "node scripts/import-public-fhir.mjs",
    "build": "vite build && bun build src/server/index.ts --outdir dist/server --target bun",
    "start": "bun dist/server/index.js",
    "check:gemini-key": "node --input-type=module -e 'if(!process.env.GEMINI_API_KEY) throw new Error(\"GEMINI_API_KEY missing\"); console.log(\"Gemini API key present\")'"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@hugeicons/core-free-icons": "^4.0.0",
    "@hugeicons/react": "^1.1.6",
    "@langchain/core": "^1.1.32",
    "@langchain/google-genai": "^2.1.25",
    "@langchain/langgraph-sdk": "^1.7.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.8.5",
    "langchain": "^1.2.32",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shadcn": "^4.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/bun": "^1.3.10",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.8.3",
    "vite": "^6.2.0"
  }
}
